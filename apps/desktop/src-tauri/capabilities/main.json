{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "LMmaster main window capability set. core:default + Phase 1A.3.c install commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-install-app",
    "allow-cancel-install",
    "allow-detect-environment",
    "allow-start-scan",
    "allow-get-last-scan",
    "allow-get-catalog",
    "allow-get-recommendation",
    "allow-start-bench",
    "allow-cancel-bench",
    "allow-get-last-bench-report",
    "allow-create-api-key",
    "allow-list-api-keys",
    "allow-revoke-api-key",
    "allow-get-workspace-fingerprint",
    "allow-check-workspace-repair",
    "allow-start-workspace-export",
    "allow-cancel-workspace-export",
    "allow-start-workspace-import",
    "allow-cancel-workspace-import",
    "allow-verify-workspace-archive",
    "allow-list-runtime-statuses",
    "allow-list-runtime-models",
    "allow-get-presets",
    "allow-get-preset",
    "allow-start-workbench-run",
    "allow-cancel-workbench-run",
    "allow-list-workbench-runs",
    "allow-workbench-preview-jsonl",
    "allow-workbench-serialize-examples",
    "allow-get-artifact-stats",
    "allow-cleanup-artifacts-now",
    "allow-ingest-path",
    "allow-cancel-ingest",
    "allow-search-knowledge",
    "allow-list-ingests",
    "allow-knowledge-workspace-stats",
    "allow-check-for-update",
    "allow-cancel-update-check",
    "allow-start-auto-update-poller",
    "allow-stop-auto-update-poller",
    "allow-get-auto-update-status",
    "allow-list-pipelines",
    "allow-set-pipeline-enabled",
    "allow-get-pipelines-config",
    "allow-get-audit-log",
    "allow-clear-audit-log",
    "allow-get-telemetry-config",
    "allow-set-telemetry-enabled",
    "allow-refresh-catalog-now",
    "allow-get-last-catalog-refresh",
    "updater:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}
