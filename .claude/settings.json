{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Glob",
      "Grep",

      "Read(**)",
      "Edit(**)",
      "Write(**)",

      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(rustup *)",
      "Bash(rustfmt *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(echo *)",
      "Bash(true)",
      "Bash(false)",

      "PowerShell(pnpm *)",
      "PowerShell(npm *)",
      "PowerShell(node *)",
      "PowerShell(npx *)",
      "PowerShell(cargo *)",
      "PowerShell(rustc *)",
      "PowerShell(rustup *)",
      "PowerShell(rustfmt *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Get-Item *)",
      "PowerShell(New-Item *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Set-Location *)",
      "PowerShell(Resolve-Path *)",
      "PowerShell(Select-Object *)",
      "PowerShell(Select-String *)",
      "PowerShell(ForEach-Object *)",
      "PowerShell(Where-Object *)",
      "PowerShell(Group-Object *)",
      "PowerShell(.\\.claude\\scripts\\*)",
      "PowerShell(./.claude/scripts/*)",
      "PowerShell(powershell *.claude*scripts*)",
      "PowerShell(powershell -ExecutionPolicy *)",
      "PowerShell(& \"$env:USERPROFILE*)",

      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "PowerShell(git push *)",
      "PowerShell(git reset --hard *)",
      "PowerShell(git checkout -- *)",
      "PowerShell(git restore *)",
      "PowerShell(git clean -f*)",
      "PowerShell(git branch -D*)",
      "PowerShell(Remove-Item *-Recurse*-Force*)",
      "PowerShell(Remove-Item *-Force*-Recurse*)",
      "PowerShell(rmdir /s *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)"
    ],
    "deny": [
      "Edit(./.git/**)",
      "Write(./.git/**)",
      "Edit(**/node_modules/**)",
      "Write(**/node_modules/**)",
      "Edit(**/target/**)",
      "Write(**/target/**)",
      "Edit(**/dist/**)",
      "Write(**/dist/**)",
      "Bash(curl *|*sh*)",
      "Bash(wget *|*sh*)",
      "PowerShell(iex *)",
      "PowerShell(Invoke-Expression *)"
    ]
  }
}
